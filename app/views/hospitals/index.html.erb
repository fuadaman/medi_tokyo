<%# ========================================
    HOSPITAL INDEX — MediTokyo
    /hospitals
    ======================================== %>

<%# ── Search Bar ─────────────────────────── %>
<div style="position:relative;margin-bottom:12px;">
  <svg style="position:absolute;left:14px;top:50%;transform:translateY(-50%);pointer-events:none;" width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="#4A7FC1" stroke-width="1.8" stroke-linecap="round">
    <circle cx="9" cy="9" r="6"/>
    <path d="M15 15l3 3"/>
  </svg>
  <input
    type="text"
    id="search-input"
    placeholder="Search hospitals, wards, cities…"
    style="width:100%;padding:12px 16px 12px 40px;background:rgba(255,255,255,0.8);border:1px solid rgba(74,127,193,0.2);border-radius:14px;font-size:13px;color:#0C2D6B;outline:none;font-family:var(--font-main);box-sizing:border-box;">
</div>

<%# ── Ward / City Jump Navigation ─────────── %>
<p style="font-size:10px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:#4A7FC1;margin-bottom:6px;"><%= t('hospitals.wards_cities') %></p>
<div class="ward-jump-nav" id="ward-jump-nav">
  <button onclick="filterByWard('')" id="pill-all" class="jump-pill active">All</button>
  <% @hospitals_by_location.each do |ward, _| %>
    <button onclick="filterByWard('<%= ward_anchor(ward) %>')" id="pill-<%= ward_anchor(ward) %>" class="jump-pill"><%= ward_short_name(ward) %></button>
  <% end %>
</div>

<%# ── Result Count ────────────────────────── %>
<p style="font-size:11px;color:#4A7FC1;margin-bottom:12px;" id="result-count">
  <%= @total_count %> facilities across <%= @hospitals_by_location.size %> wards &amp; cities
</p>

<%# ── Grouped Hospital Sections ───────────── %>
<div id="hospitals-list">
  <% @hospitals_by_location.each_with_index do |(ward, ward_hospitals), idx| %>
    <section class="ward-section" id="<%= ward_anchor(ward) %>">

      <%# Section header with count badge %>
      <div class="ward-header">
        <h2 class="ward-title"><%= ward %></h2>
        <span class="ward-count-badge"><%= ward_hospitals.size %></span>
      </div>

      <%# Hospital cards for this ward %>
      <% ward_hospitals.each do |hospital| %>
        <%
          langs     = parse_languages(hospital.insurance_notes_en)
          type_lbl  = hospital_type_label(hospital)
          type_css  = hospital_type_css(hospital)
        %>
        <a href="<%= hospital_path(hospital) %>"
           class="hospital-card"
           data-name="<%= hospital.name_en.to_s.downcase %>"
           data-ward="<%= hospital.ward.to_s.downcase %>"
           data-government="<%= hospital.is_government? %>"
           data-certified="<%= hospital.is_certified? %>"
           data-emergency="<%= hospital.specialties.any? { |s| s.name_en == 'Emergency Medicine' } %>"
           data-maternity="<%= hospital.specialties.any? { |s| s.name_en.include?('Maternity') } %>">

          <%# Name row + type badge + chevron %>
          <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:5px;">
            <div style="flex:1;min-width:0;padding-right:8px;">
              <p class="hosp-name"><%= hospital.name_en %></p>
              <% if hospital.name_jp.present? %>
                <p class="hosp-jp"><%= hospital.name_jp %></p>
              <% end %>
            </div>
            <div style="display:flex;align-items:center;gap:6px;flex-shrink:0;margin-top:1px;">
              <span class="type-badge type-badge--<%= type_css %>"><%= type_lbl %></span>
              <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="#4A7FC1" stroke-width="1.5" stroke-linecap="round">
                <path d="M7 10h6M13 10l-3-3M13 10l-3 3"/>
              </svg>
            </div>
          </div>

          <%# Phone + languages row %>
          <div class="hosp-meta-row">
            <% if hospital.phone.present? %>
              <span class="hosp-phone">
                <svg width="11" height="11" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="vertical-align:middle;margin-right:2px;">
                  <path d="M3 3h4l2 5-2.5 1.5a11 11 0 005 5L13 12l5 2v4a2 2 0 01-2 2C6 20 0 14 0 5a2 2 0 012-2z"/>
                </svg><%= hospital.phone %>
              </span>
            <% end %>
            <% if langs.any? %>
              <div class="lang-tags">
                <% langs.first(3).each do |lang| %>
                  <span class="tag tag-green"><%= lang %></span>
                <% end %>
                <% if langs.size > 3 %>
                  <span class="tag tag-sky">+<%= langs.size - 3 %> more</span>
                <% end %>
              </div>
            <% end %>
          </div>

          <%# Insurance / status tags (shown only when set) %>
          <% has_tags = hospital.is_government? || hospital.is_certified? || hospital.accepts_shakai_hoken? || hospital.accepts_kokumin_hoken? || hospital.accepts_travel_insurance? || hospital.specialties.any? { |s| s.name_en == "Emergency Medicine" } || hospital.specialties.any? { |s| s.name_en.include?("Maternity") } %>
          <% if has_tags %>
            <div class="tag-row" style="margin-top:6px;">
              <% if hospital.is_government? %>
                <span class="tag tag-navy">Government</span>
              <% end %>
              <% if hospital.is_certified? %>
                <span class="tag tag-sky">Certified</span>
              <% end %>
              <% if hospital.accepts_shakai_hoken? %>
                <span class="tag tag-sky">Shakai Hoken</span>
              <% end %>
              <% if hospital.accepts_kokumin_hoken? %>
                <span class="tag tag-sky">Kokumin Hoken</span>
              <% end %>
              <% if hospital.accepts_travel_insurance? %>
                <span class="tag tag-amber">Travel Insurance</span>
              <% end %>
              <% if hospital.specialties.any? { |s| s.name_en == "Emergency Medicine" } %>
                <span class="tag tag-red">24h Emergency</span>
              <% end %>
              <% if hospital.specialties.any? { |s| s.name_en.include?("Maternity") } %>
                <span class="tag tag-pink">Maternity</span>
              <% end %>
            </div>
          <% end %>

        </a>
      <% end %>
    </section>

    <%# Divider between sections (not after the last one) %>
    <% unless idx == @hospitals_by_location.size - 1 %>
      <div class="ward-divider"></div>
    <% end %>
  <% end %>
</div>

<%# No results message %>
<div id="no-results" style="display:none;text-align:center;padding:40px 20px;">
  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#7EB8F7" stroke-width="1.5" stroke-linecap="round" style="margin:0 auto 12px;display:block;">
    <circle cx="11" cy="11" r="8"/>
    <path d="M21 21l-4.35-4.35"/>
  </svg>
  <p style="font-size:14px;font-weight:500;color:#0C2D6B;margin-bottom:4px;">No facilities found</p>
  <p style="font-size:12px;color:#4A7FC1;">Try adjusting your search or filters</p>
</div>

<script>
  let activeWard = '';

  // ── Ward / city filter ──────────────────────────────────────
  function filterByWard(wardId) {
    activeWard = wardId;

    document.querySelectorAll('.jump-pill').forEach(p => p.classList.remove('active'));
    const activePill = document.getElementById(wardId ? 'pill-' + wardId : 'pill-all');
    if (activePill) activePill.classList.add('active');

    applyFilters();
  }

  // ── Core filter logic ───────────────────────────────────────
  function applyFilters() {
    const searchVal = (document.getElementById('search-input')?.value || '').toLowerCase();
    const cards     = document.querySelectorAll('#hospitals-list .hospital-card');
    let   visible   = 0;

    cards.forEach(card => {
      const name    = card.dataset.name || '';
      const ward    = card.dataset.ward || '';
      const section = card.closest('.ward-section');

      const matchWard   = !activeWard || (section && section.id === activeWard);
      const matchSearch = !searchVal  || name.includes(searchVal) || ward.includes(searchVal);

      const show = matchWard && matchSearch;
      card.style.display = show ? 'block' : 'none';
      if (show) visible++;
    });

    // Hide ward sections where every card is filtered out
    document.querySelectorAll('.ward-section').forEach(section => {
      const sectionCards = section.querySelectorAll('.hospital-card');
      const anyVisible   = Array.from(sectionCards).some(c => c.style.display !== 'none');
      section.style.display = anyVisible ? 'block' : 'none';

      const pill = document.getElementById('pill-' + section.id);
      if (pill) pill.style.opacity = anyVisible ? '1' : '0.3';
    });

    // Hide dividers that follow a hidden section
    document.querySelectorAll('.ward-divider').forEach(divider => {
      const prev = divider.previousElementSibling;
      divider.style.display = (prev && prev.style.display === 'none') ? 'none' : 'block';
    });

    const countEl = document.getElementById('result-count');
    if (countEl) countEl.textContent = `${visible} facilities found`;

    const noResults = document.getElementById('no-results');
    if (noResults) noResults.style.display = visible === 0 ? 'block' : 'none';
  }

  // ── Event listeners ─────────────────────────────────────────
  document.addEventListener('DOMContentLoaded', () => {
    const input = document.getElementById('search-input');
    if (input) input.addEventListener('input', applyFilters);
  });

  // ── Honour URL params ───────────────────────────────────────
  document.addEventListener('turbo:load', () => {
    const p = new URLSearchParams(window.location.search);

    const q = p.get('q');
    if (q) {
      const input = document.getElementById('search-input');
      if (input) { input.value = q; applyFilters(); }
    }

  });
</script>
