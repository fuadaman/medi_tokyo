<%# ========================================
    EMERGENCY PAGE — MediTokyo
    /emergency
    ======================================== %>

<%# Hero Banner %>
<div style="background:linear-gradient(135deg,rgba(226,75,74,0.12),rgba(226,75,74,0.06));backdrop-filter:blur(40px);border:1px solid rgba(226,75,74,0.2);border-radius:16px;padding:20px;margin-bottom:16px;text-align:center;position:relative;overflow:hidden;box-shadow:inset 0 1px 0 rgba(255,255,255,0.8);">
  <div style="width:56px;height:56px;background:rgba(226,75,74,0.1);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#E24B4A" stroke-width="2" stroke-linecap="round">
      <circle cx="12" cy="12" r="10"/>
      <path d="M12 7v5M12 16h.01" stroke-width="2.5"/>
    </svg>
  </div>
  <h1 style="font-size:18px;font-weight:600;color:#E24B4A;margin-bottom:4px;">Emergency / 緊急</h1>
  <p style="font-size:12px;color:rgba(226,75,74,0.7);">Tap any number to call immediately</p>
</div>

<%# Emergency Numbers %>
<p style="font-size:10px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:#4A7FC1;margin-bottom:8px;">Emergency Numbers</p>

<% @emergency_contacts.each do |contact| %>
  <div style="background:rgba(255,255,255,0.7);backdrop-filter:blur(40px);border-radius:16px;padding:16px;margin-bottom:10px;box-shadow:inset 0 1px 0 rgba(255,255,255,0.8);<%= contact.number == '119' || contact.number == '110' ? 'border:1px solid rgba(226,75,74,0.15);' : 'border:1px solid rgba(74,127,193,0.15);' %>">
    <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px;">
      <div style="flex:1;">
        <p style="font-size:<%= contact.number == '119' || contact.number == '110' ? '32px' : '18px' %>;font-weight:700;color:<%= contact.number == '119' || contact.number == '110' ? '#E24B4A' : '#0C2D6B' %>;line-height:1;margin-bottom:4px;"><%= contact.number %></p>
        <p style="font-size:13px;font-weight:600;color:#0C2D6B;margin-bottom:2px;"><%= contact.name_en %></p>
        <p style="font-size:11px;color:#4A7FC1;"><%= contact.name_jp %></p>
      </div>
      <a href="tel:<%= contact.number %>" style="background:<%= contact.number == '119' || contact.number == '110' ? '#E24B4A' : 'linear-gradient(135deg,#4A7FC1,#0C2D6B)' %>;color:#fff;font-size:12px;font-weight:600;padding:10px 16px;border-radius:12px;text-decoration:none;display:flex;align-items:center;gap:6px;flex-shrink:0;box-shadow:0 4px 12px rgba(12,45,107,0.2);">
        <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round"><path d="M3 3h4l2 5-2.5 1.5a11 11 0 005 5L13 12l5 2v4a2 2 0 01-2 2C6 20 0 14 0 5a2 2 0 012-2z"/></svg>
        Call
      </a>
    </div>
    <p style="font-size:11px;color:#4A7FC1;line-height:1.6;"><%= contact.description_en %></p>
  </div>
<% end %>

<%# What to do section %>
<p style="font-size:10px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:#4A7FC1;margin-bottom:8px;margin-top:8px;">What to do in an emergency</p>

<div style="background:rgba(255,255,255,0.7);backdrop-filter:blur(40px);border-radius:16px;padding:16px;margin-bottom:12px;box-shadow:inset 0 1px 0 rgba(255,255,255,0.8);">

  <% steps = [
    { num: "1", en: "Stay calm and call 119 immediately", jp: "落ち着いて、すぐに119番に電話してください" },
    { num: "2", en: "Say 'Kyuukyuu desu' (救急です) — It's an emergency", jp: "「救急です」と伝えてください" },
    { num: "3", en: "Give your location clearly — street name or landmark", jp: "現在地を明確に伝えてください" },
    { num: "4", en: "Describe symptoms as clearly as possible", jp: "症状をできるだけ明確に説明してください" },
    { num: "5", en: "English operators available 24 hours", jp: "英語対応オペレーターが24時間対応" }
  ] %>

  <% steps.each_with_index do |step, index| %>
    <div style="display:flex;gap:12px;align-items:flex-start;<%= index < steps.length - 1 ? 'margin-bottom:14px;padding-bottom:14px;border-bottom:1px solid rgba(74,127,193,0.08);' : '' %>">
      <div style="width:28px;height:28px;border-radius:50%;background:rgba(12,45,107,0.08);color:#0C2D6B;font-size:12px;font-weight:600;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <%= step[:num] %>
      </div>
      <div>
        <p style="font-size:12px;font-weight:500;color:#0C2D6B;margin-bottom:2px;line-height:1.5;"><%= step[:en] %></p>
        <p style="font-size:10px;color:#4A7FC1;"><%= step[:jp] %></p>
      </div>
    </div>
  <% end %>

</div>

<%# First Aid Tips %>
<p style="font-size:10px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:#4A7FC1;margin-bottom:8px;">Basic First Aid</p>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:16px;">

  <div style="background:rgba(255,255,255,0.7);backdrop-filter:blur(40px);border-radius:14px;padding:14px;box-shadow:inset 0 1px 0 rgba(255,255,255,0.8);">
    <div style="width:36px;height:36px;background:rgba(226,75,74,0.08);border-radius:10px;display:flex;align-items:center;justify-content:center;margin-bottom:8px;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#E24B4A" stroke-width="1.8" stroke-linecap="round">
        <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
      </svg>
    </div>
    <p style="font-size:11px;font-weight:600;color:#0C2D6B;margin-bottom:4px;">CPR</p>
    <p style="font-size:10px;color:#4A7FC1;line-height:1.5;">30 chest compressions, 2 rescue breaths. Repeat until help arrives.</p>
  </div>

  <div style="background:rgba(255,255,255,0.7);backdrop-filter:blur(40px);border-radius:14px;padding:14px;box-shadow:inset 0 1px 0 rgba(255,255,255,0.8);">
    <div style="width:36px;height:36px;background:rgba(226,75,74,0.08);border-radius:10px;display:flex;align-items:center;justify-content:center;margin-bottom:8px;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#E24B4A" stroke-width="1.8" stroke-linecap="round">
        <path d="M12 2v20M2 12h20"/>
      </svg>
    </div>
    <p style="font-size:11px;font-weight:600;color:#0C2D6B;margin-bottom:4px;">Bleeding</p>
    <p style="font-size:10px;color:#4A7FC1;line-height:1.5;">Apply firm pressure with clean cloth. Keep pressure until help arrives.</p>
  </div>

  <div style="background:rgba(255,255,255,0.7);backdrop-filter:blur(40px);border-radius:14px;padding:14px;box-shadow:inset 0 1px 0 rgba(255,255,255,0.8);">
    <div style="width:36px;height:36px;background:rgba(226,75,74,0.08);border-radius:10px;display:flex;align-items:center;justify-content:center;margin-bottom:8px;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#E24B4A" stroke-width="1.8" stroke-linecap="round">
        <circle cx="12" cy="12" r="10"/>
        <path d="M8 12s1.5 3 4 3 4-3 4-3"/>
        <path d="M9 9h.01M15 9h.01"/>
      </svg>
    </div>
    <p style="font-size:11px;font-weight:600;color:#0C2D6B;margin-bottom:4px;">Choking</p>
    <p style="font-size:10px;color:#4A7FC1;line-height:1.5;">5 back blows, then 5 abdominal thrusts. Call 119 immediately.</p>
  </div>

  <div style="background:rgba(255,255,255,0.7);backdrop-filter:blur(40px);border-radius:14px;padding:14px;box-shadow:inset 0 1px 0 rgba(255,255,255,0.8);">
    <div style="width:36px;height:36px;background:rgba(226,75,74,0.08);border-radius:10px;display:flex;align-items:center;justify-content:center;margin-bottom:8px;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#E24B4A" stroke-width="1.8" stroke-linecap="round">
        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/>
        <path d="M12 8v4M12 16h.01"/>
      </svg>
    </div>
    <p style="font-size:11px;font-weight:600;color:#0C2D6B;margin-bottom:4px;">Burns</p>
    <p style="font-size:10px;color:#4A7FC1;line-height:1.5;">Cool with running water for 10 min. Do not use ice or butter.</p>
  </div>

</div>

<%# Disclaimer %>
<div style="background:rgba(74,127,193,0.05);border:1px solid rgba(74,127,193,0.12);border-radius:12px;padding:12px;margin-bottom:8px;">
  <p style="font-size:10px;color:#4A7FC1;line-height:1.6;text-align:center;">
    This is basic guidance only. Always call 119 in a medical emergency. MediTokyo is not a substitute for professional medical advice.
  </p>
</div>
