<%# Emergency Banner %>
<div style="background:rgba(226,75,74,0.1);border:1px solid rgba(226,75,74,0.25);border-radius:16px;padding:14px 16px;display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
  <div style="display:flex;flex-direction:column;gap:2px;">
    <span style="font-size:13px;font-weight:600;color:#E24B4A;">Emergency / 緊急</span>
    <span style="font-size:10px;color:rgba(226,75,74,0.7);">Tap to call immediately</span>
  </div>
  <div style="display:flex;flex-direction:row;gap:6px;">
    <a href="tel:119" style="background:#E24B4A;color:#fff;font-size:13px;font-weight:600;padding:8px 16px;border-radius:10px;text-decoration:none;display:flex;align-items:center;gap:4px;">
      <svg width="12" height="12" viewBox="0 0 20 20" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round"><path d="M3 3h4l2 5-2.5 1.5a11 11 0 005 5L13 12l5 2v4a2 2 0 01-2 2C6 20 0 14 0 5a2 2 0 012-2z"/></svg>
      119
    </a>
    <a href="tel:110" style="background:#E24B4A;color:#fff;font-size:13px;font-weight:600;padding:8px 16px;border-radius:10px;text-decoration:none;display:flex;align-items:center;gap:4px;">
      <svg width="12" height="12" viewBox="0 0 20 20" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round"><path d="M3 3h4l2 5-2.5 1.5a11 11 0 005 5L13 12l5 2v4a2 2 0 01-2 2C6 20 0 14 0 5a2 2 0 012-2z"/></svg>
      110
    </a>
  </div>
</div>

<%# Search Bar %>
<form action="<%= hospitals_path %>" method="get" style="position:relative;margin-bottom:12px;">
  <svg style="position:absolute;left:14px;top:50%;transform:translateY(-50%);pointer-events:none;" width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="#4A7FC1" stroke-width="1.8" stroke-linecap="round"><circle cx="9" cy="9" r="6"/><path d="M15 15l3 3"/></svg>
  <input type="text" name="q" placeholder="Search hospitals, wards, specialties..." style="width:100%;padding:12px 16px 12px 40px;background:rgba(255,255,255,0.5);border:1px solid rgba(255,255,255,0.8);border-radius:12px;font-size:13px;color:#0C2D6B;outline:none;font-family:var(--font-main);box-sizing:border-box;">
</form>

<%# Nearby Hospitals %>
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
  <p class="section-label" style="margin:0;">Nearby hospitals</p>
  <a href="<%= hospitals_path %>" style="font-size:11px;font-weight:500;color:#4A7FC1;text-decoration:none;">See all →</a>
</div>

<% @hospitals.first(4).each do |hospital| %>
  <a href="<%= hospital_path(hospital) %>" class="hospital-card">
    <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:6px;">
      <div>
        <p class="hosp-name"><%= locale_field(hospital, :name) %></p>
        <p class="hosp-jp"><%= I18n.locale == :ja ? hospital.name_en : hospital.name_jp %></p>
        <p class="hosp-meta"><%= hospital.ward %> · <%= hospital.phone %></p>
      </div>
      <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="#4A7FC1" stroke-width="1.5" stroke-linecap="round"><path d="M7 10h6M13 10l-3-3M13 10l-3 3"/></svg>
    </div>
    <div class="tag-row">
      <% if hospital.is_government? %>
        <span class="tag tag-navy">Government</span>
      <% end %>
      <% if hospital.is_certified? %>
        <span class="tag tag-sky">Certified</span>
      <% end %>
      <% if hospital.accepts_shakai_hoken? %>
        <span class="tag tag-sky">Shakai Hoken</span>
      <% end %>
      <% if hospital.accepts_kokumin_hoken? %>
        <span class="tag tag-sky">Kokumin Hoken</span>
      <% end %>
      <% if hospital.specialties.any? { |s| s.name_en == "Emergency Medicine" } %>
        <span class="tag tag-red">24h Emergency</span>
      <% end %>
      <% if hospital.specialties.any? { |s| s.name_en.include?("Maternity") } %>
        <span class="tag tag-pink">Maternity</span>
      <% end %>
    </div>
  </a>
<% end %>

<%# Insurance Info Banner %>
<div style="background:rgba(255,255,255,0.22);backdrop-filter:blur(40px);border-radius:16px;padding:16px;display:flex;gap:12px;align-items:flex-start;margin-top:8px;box-shadow:inset 0 1px 0 rgba(255,255,255,0.75);">
  <div style="width:40px;height:40px;background:rgba(74,127,193,0.1);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4A7FC1" stroke-width="1.8" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01" stroke-width="2"/></svg>
  </div>
  <div>
    <p style="font-size:12px;font-weight:600;color:#0C2D6B;margin-bottom:4px;">Did you know?</p>
    <p style="font-size:11px;color:#4A7FC1;line-height:1.6;margin-bottom:6px;">Japanese health insurance covers <strong style="color:#0C2D6B;">70%</strong> of medical costs. New mothers receive <strong style="color:#0C2D6B;">¥500,000</strong> childbirth allowance.</p>
    <a href="<%= insurance_guide_path %>" style="font-size:11px;font-weight:500;color:#4A7FC1;text-decoration:none;">Learn about Hoken →</a>
  </div>
</div>
